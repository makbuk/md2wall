FONT_BOLD        = None  # e.g. "/usr/share/fonts/truetype/jetbrains-mono/JetBrainsMono-Bold.ttf"
FONT_ITALIC      = None  # e.g. "/usr/share/fonts/truetype/jetbrains-mono/JetBrainsMono-Italic.ttf"
